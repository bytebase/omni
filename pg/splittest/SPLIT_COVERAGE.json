[
  {"id": "c1-001", "class": "C1-plain-string", "form": "in", "sql": "SELECT 'a;b';", "want": ["SELECT 'a;b';"], "truth_source": "spec:scan.l"},
  {"id": "c1-002", "class": "C1-plain-string", "form": "boundary", "sql": "SELECT 'it''s;x'; SELECT 2;", "want": ["SELECT 'it''s;x';", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "'' doubling"},
  {"id": "c1-003", "class": "C1-plain-string", "form": "boundary", "sql": "SELECT 'a\\'; SELECT 2;", "want": ["SELECT 'a\\';", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "conforming=on: backslash literal in plain string; D1 negative fence"},
  {"id": "c1-004", "class": "C1-plain-string", "form": "out", "sql": "SELECT 'unterminated;", "want": ["SELECT 'unterminated;"], "truth_source": "spec:psqlscan", "notes": "unterminated string buffers to EOF"},
  {"id": "c2-001", "class": "C2-escape-string", "form": "in", "sql": "SELECT E'a\\';b';", "want": ["SELECT E'a\\';b';"], "truth_source": "container", "notes": "audit D1, PR #374"},
  {"id": "c2-002", "class": "C2-escape-string", "form": "boundary", "sql": "SELECT E'a\\\\'; SELECT 2;", "want": ["SELECT E'a\\\\';", " SELECT 2;"], "truth_source": "container", "notes": "even backslashes close"},
  {"id": "c2-003", "class": "C2-escape-string", "form": "boundary", "sql": "SELECT e'x''y\\';z';", "want": ["SELECT e'x''y\\';z';"], "truth_source": "container", "notes": "lowercase prefix + doubled quote + escaped quote"},
  {"id": "c2-004", "class": "C2-escape-string", "form": "out", "sql": "SELECT abcE'x\\'; SELECT 2;", "want": ["SELECT abcE'x\\';", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "identifier tail: not an E prefix, plain-string rules"},
  {"id": "c3-001", "class": "C3-unicode-string", "form": "in", "sql": "SELECT U&'d\\0061t;a';", "want": ["SELECT U&'d\\0061t;a';"], "truth_source": "container", "notes": "U& lexes with plain quote rules; backslash not special at boundary"},
  {"id": "c3-002", "class": "C3-unicode-string", "form": "boundary", "sql": "SELECT U&'a\\'; SELECT 2;", "want": ["SELECT U&'a\\';", " SELECT 2;"], "truth_source": "container", "notes": "backslash does not escape closing quote in U& strings"},
  {"id": "c4-001", "class": "C4-bit-string", "form": "in", "sql": "SELECT B'01;10';", "want": ["SELECT B'01;10';"], "truth_source": "spec:scan.l", "notes": "splitter seals to closing quote without content validation"},
  {"id": "c4-002", "class": "C4-bit-string", "form": "boundary", "sql": "SELECT x'ff'; SELECT 2;", "want": ["SELECT x'ff';", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "lowercase hex prefix"},
  {"id": "c5-001", "class": "C5-dollar-quote", "form": "in", "sql": "SELECT $$a;b$$;", "want": ["SELECT $$a;b$$;"], "truth_source": "spec:scan.l"},
  {"id": "c5-002", "class": "C5-dollar-quote", "form": "boundary", "sql": "SELECT $tag$ $x$ ; $tag$; SELECT 2;", "want": ["SELECT $tag$ $x$ ; $tag$;", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "similar tag substring inside body"},
  {"id": "c5-003", "class": "C5-dollar-quote", "form": "boundary", "sql": "SELECT $Tag$x$tag$;y$Tag$;", "want": ["SELECT $Tag$x$tag$;y$Tag$;"], "truth_source": "spec:scan.l", "notes": "tags are case-sensitive"},
  {"id": "c5-004", "class": "C5-dollar-quote", "form": "out", "sql": "SELECT $$never closed;", "want": ["SELECT $$never closed;"], "truth_source": "spec:psqlscan", "notes": "unterminated buffers to EOF"},
  {"id": "c6-001", "class": "C6-ident-dollar", "form": "in", "sql": "SELECT 1 AS abc$x$y; SELECT 2;", "want": ["SELECT 1 AS abc$x$y;", " SELECT 2;"], "truth_source": "container", "notes": "audit D3, PR #375: $ continues identifier"},
  {"id": "c6-002", "class": "C6-ident-dollar", "form": "boundary", "sql": "SELECT _a$t$b; SELECT $t$x;$t$;", "want": ["SELECT _a$t$b;", " SELECT $t$x;$t$;"], "truth_source": "container", "notes": "ident-dollar then true dollar-quote after non-ident byte"},
  {"id": "c6-003", "class": "C6-ident-dollar", "form": "boundary", "sql": "SELECT $1::int; SELECT 2;", "want": ["SELECT $1::int;", " SELECT 2;"], "truth_source": "container", "notes": "positional parameter unaffected"},
  {"id": "c6-004", "class": "C6-ident-dollar", "form": "out", "sql": "SELECT 123$t$a;b$t$;", "want": ["SELECT 123$t$a;", "b$t$;"], "truth_source": "spec:psqlscan", "notes": "documented divergence: digit is ident-continuation byte so no dollar-quote opens; adjacent literals are never valid grammar, difference only moves an error boundary (PR #375)"},
  {"id": "c7-001", "class": "C7-line-comment", "form": "in", "sql": "SELECT 1 --x;y\n;", "want": ["SELECT 1 --x;y\n;"], "truth_source": "spec:scan.l"},
  {"id": "c7-002", "class": "C7-line-comment", "form": "boundary", "sql": "SELECT 1; --tail;note", "want": ["SELECT 1;", " --tail;note"], "truth_source": "spec:scan.l", "notes": "EOF without newline; trailing trivia segment"},
  {"id": "c8-001", "class": "C8-block-comment", "form": "in", "sql": "SELECT /*a;b*/ 1;", "want": ["SELECT /*a;b*/ 1;"], "truth_source": "spec:scan.l"},
  {"id": "c8-002", "class": "C8-block-comment", "form": "boundary", "sql": "SELECT /* /*nested;*/ still; */ 1; SELECT 2;", "want": ["SELECT /* /*nested;*/ still; */ 1;", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "PG block comments nest"},
  {"id": "c8-003", "class": "C8-block-comment", "form": "out", "sql": "SELECT /* open; SELECT 2;", "want": ["SELECT /* open; SELECT 2;"], "truth_source": "spec:psqlscan", "notes": "unterminated comment buffers to EOF"},
  {"id": "c9-001", "class": "C9-quoted-ident", "form": "in", "sql": "SELECT \"a;b\" FROM t;", "want": ["SELECT \"a;b\" FROM t;"], "truth_source": "spec:scan.l"},
  {"id": "c9-002", "class": "C9-quoted-ident", "form": "boundary", "sql": "SELECT \"x\"\"y;z\"; SELECT 2;", "want": ["SELECT \"x\"\"y;z\";", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "\"\" doubling"},
  {"id": "c10-001", "class": "C10-paren-depth", "form": "in", "sql": "CREATE RULE r AS ON UPDATE TO t DO ALSO (SELECT 1; SELECT 2); SELECT 3;", "want": ["CREATE RULE r AS ON UPDATE TO t DO ALSO (SELECT 1; SELECT 2);", " SELECT 3;"], "truth_source": "container", "notes": "audit D2, PR #376"},
  {"id": "c10-002", "class": "C10-paren-depth", "form": "boundary", "sql": "SELECT 1); SELECT 2;", "want": ["SELECT 1);", " SELECT 2;"], "truth_source": "spec:psqlscan", "notes": "stray ) clamps at zero, splitting continues"},
  {"id": "c10-003", "class": "C10-paren-depth", "form": "out", "sql": "SELECT (1; SELECT 2;", "want": ["SELECT (1; SELECT 2;"], "truth_source": "spec:psqlscan", "notes": "unclosed ( buffers remainder as one segment"},
  {"id": "c11-001", "class": "C11-begin-atomic", "form": "in", "sql": "CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT 1; SELECT 2; END; SELECT 3;", "want": ["CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT 1; SELECT 2; END;", " SELECT 3;"], "truth_source": "container"},
  {"id": "c11-002", "class": "C11-begin-atomic", "form": "boundary", "sql": "CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT t4.end FROM t4; END; SELECT 1;", "want": ["CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT t4.end FROM t4; END;", " SELECT 1;"], "truth_source": "container", "notes": "audit D4, PR #380: dotted end does not close the block; known-better vs psql (see KnownBetterThanPsql)"},
  {"id": "c11-003", "class": "C11-begin-atomic", "form": "boundary", "sql": "CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT CASE WHEN a THEN 1 ELSE 2 END; END; SELECT 1;", "want": ["CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT CASE WHEN a THEN 1 ELSE 2 END; END;", " SELECT 1;"], "truth_source": "container", "notes": "CASE END pairing preserved"},
  {"id": "c11-004", "class": "C11-begin-atomic", "form": "out", "sql": "SELECT begin FROM t; SELECT 2;", "want": ["SELECT begin FROM t;", " SELECT 2;"], "truth_source": "container", "notes": "bare begin as column does not open a block (PR #380 hardening)"},
  {"id": "c12-001", "class": "C12-copy-stdin", "form": "in", "sql": "COPY t FROM stdin;\na;b\nc;d\n\\.\n", "want": ["COPY t FROM stdin;\na;b\nc;d\n\\.\n"], "truth_source": "container", "notes": "audit D5, PR #378: data attaches to the COPY segment through the terminator line and its newline"},
  {"id": "c12-002", "class": "C12-copy-stdin", "form": "boundary", "sql": "COPY t FROM stdin;\n1\t\\N\n\\.\nSELECT 1;", "want": ["COPY t FROM stdin;\n1\t\\N\n\\.\n", "SELECT 1;"], "truth_source": "container", "notes": "pg_dump form with \\N nulls; PR #379 keeps Parse clean"},
  {"id": "c12-003", "class": "C12-copy-stdin", "form": "boundary", "sql": "SELECT 0;\n\\restrict x\nCOPY t FROM stdin;\na;b\n\\.\n", "want": ["SELECT 0;", "\n\\restrict x\nCOPY t FROM stdin;\na;b\n\\.\n"], "truth_source": "container", "notes": "audit D6b, PR #383: metacommand trivia must not shadow COPY detection (pg_dumpall shape)"},
  {"id": "c12-004", "class": "C12-copy-stdin", "form": "out", "sql": "COPY t FROM 'file'; SELECT 1;", "want": ["COPY t FROM 'file';", " SELECT 1;"], "truth_source": "container", "notes": "file source: no data mode"},
  {"id": "c12-005", "class": "C12-copy-stdin", "form": "out", "sql": "COPY (SELECT a FROM stdin) TO stdout; SELECT 1;", "want": ["COPY (SELECT a FROM stdin) TO stdout;", " SELECT 1;"], "truth_source": "container", "notes": "stdin as relation name inside parens does not match"},
  {"id": "c13-001", "class": "C13-semicolon-variants", "form": "in", "sql": "SELECT 1;;SELECT 2;", "want": ["SELECT 1;", ";", "SELECT 2;"], "truth_source": "invariant", "notes": "bare semicolon forms an Empty segment"},
  {"id": "c13-002", "class": "C13-semicolon-variants", "form": "boundary", "sql": "SELECT 1", "want": ["SELECT 1"], "truth_source": "spec:psqlscan", "notes": "no trailing semicolon"},
  {"id": "c14-001", "class": "C14-encoding", "form": "in", "sql": "SELECT '名前;テスト' AS 名;", "want": ["SELECT '名前;テスト' AS 名;"], "truth_source": "invariant", "notes": "multibyte content and identifier"},
  {"id": "c14-002", "class": "C14-encoding", "form": "boundary", "sql": "﻿SELECT 1; SELECT 2;", "want": ["﻿SELECT 1;", " SELECT 2;"], "truth_source": "invariant", "notes": "BOM prefix stays in first segment (lossless)"},
  {"id": "c15-001", "class": "C15-resilience", "form": "in", "sql": "SELECT E'trail\\", "want": ["SELECT E'trail\\"], "truth_source": "invariant", "notes": "trailing backslash at EOF must not scan past input"},
  {"id": "c15-002", "class": "C15-resilience", "form": "boundary", "sql": "", "want": [], "truth_source": "invariant", "notes": "empty input yields no segments"},
  {"id": "c16-001", "class": "C16-boundary-misc", "form": "in", "sql": "  \n\t SELECT 1;", "want": ["  \n\t SELECT 1;"], "truth_source": "invariant", "notes": "leading whitespace belongs to the segment"},
  {"id": "c16-002", "class": "C16-boundary-misc", "form": "boundary", "sql": "SELECT 1;\n\n-- note\n", "want": ["SELECT 1;", "\n\n-- note\n"], "truth_source": "invariant", "notes": "trailing trivia segment is Empty"},
  {"id": "c17-001", "class": "C17-keyword-boundary", "form": "in", "sql": "SELECT atomicity, beginning, ending FROM t; SELECT 2;", "want": ["SELECT atomicity, beginning, ending FROM t;", " SELECT 2;"], "truth_source": "spec:scan.l", "notes": "keyword prefixes must not trigger block tracking"},
  {"id": "c17-002", "class": "C17-keyword-boundary", "form": "boundary", "sql": "CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT 1 AS end; END; SELECT 2;", "want": ["CREATE FUNCTION f() RETURNS int LANGUAGE sql BEGIN ATOMIC SELECT 1 AS end; END;", " SELECT 2;"], "truth_source": "container", "notes": "AS end alias does not close the block (PR #380)"},
  {"id": "c18-001", "class": "C18-metacommand", "form": "in", "sql": "SELECT 1;\n\\restrict abc\nSELECT 2;", "want": ["SELECT 1;", "\n\\restrict abc\nSELECT 2;"], "truth_source": "container", "notes": "audit D6, PR #382: metacommand line is boundary-neutral trivia inside the following segment"},
  {"id": "c18-002", "class": "C18-metacommand", "form": "boundary", "sql": "SELECT 1;\n\\unrestrict x\n", "want": ["SELECT 1;", "\n\\unrestrict x\n"], "truth_source": "container", "notes": "trailing metacommand line forms an Empty trivia segment"},
  {"id": "c18-003", "class": "C18-metacommand", "form": "boundary", "sql": "SELECT 1;\n\\if (bogus; 'q\nSELECT 2;", "want": ["SELECT 1;", "\n\\if (bogus; 'q\nSELECT 2;"], "truth_source": "container", "notes": "metacommand content (parens, quotes, semicolons) never affects boundaries — the D6 counterexample class"},
  {"id": "c18-004", "class": "C18-metacommand", "form": "out", "sql": "SELECT 'str\n\\restrict inside';", "want": ["SELECT 'str\n\\restrict inside';"], "truth_source": "container", "notes": "line-start backslash inside a string is not a metacommand (scanner state isolation)"}
]
